	.byte	0,0, 374,374, 3,3, 0,0, 0,0, 377,377, 17,17, 0,0, 300,300, 377,377, 77,77, 0,0, 360,360, 377,377, 377,377, 0,0, 374,14, 377,377, 377,17, 3,3, 374,274, 377,374, 377,343, 3,3, 377,277, 377,0, 377,340, 17,17, 377,277, 377,370, 377,342, 17,17, 377,277, 377,372, 377,352, 17,17, 377,377, 377,377, 377,377, 17,17, 374,374, 377,252, 377,372, 3,3, 300,200, 377,252, 77,52, 0,0, 300,200, 377,252, 377,52, 3,0, 360,0, 377,252, 377,2, 17,0, 360,0, 377,250, 377,0, 17,0, 360,0, 377,240, 377,0, 3,0
