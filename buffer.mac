	.title	BUFFER
	
@include aloader.mac

FIELD_DX =: 16.
FIELD_DY =: 16.

Main:	call	InitTBuf

10$:	mov	TileExtMin, TileExtCur
	; animate coins
	call	CoinsAni
	; mario
	mov	#Mario, R0
	call	PrepareSprite
	call	BufferSprite
	call	MarioMove
	; gumba
	mov	#Gumba, R0
	call	PrepareSprite	
	call	BufferSprite
	call	GumbaMove
	; shroom
	mov	#Shroom, R0
	call	PrepareSprite	
	call	BufferSprite
	call	ShroomMove
	; update screen
	call	UpdateScreen
	inc	FrameCnt
	br	10$


; move mario a bit
MarioMove:
	mov	#Mario, R4
	mov	#MarioMoveY, R5
	mov	(R5)+, R0
	add	R0, R5
	movb	(R5), R0
	add	R0, C_SPR_Y(R4)
	inc	MarioMoveY
	cmp	MarioMoveY, #MarioMoveYEnd-MarioMoveY-2
	blo	10$
	clr	MarioMoveY
10$:	mov	#SpriteData004, C_SPR_IDATA(R4)
	cmp 	C_SPR_Y(R4), #11.*16.
	beq	99$
	mov	#SpriteData006, C_SPR_IDATA(R4)
99$:	return

MarioMoveY:
	.word	0
	.radix	10
	.byte	0, 0, 0, 0, 0, 0, 0, 0, -10, -8, -6, -4, -2, -1, -1, 0, 0, 0, +1, +1, +2, +4, +6, +8, +10, 0, 0, 0, 0, 0, 0, 0, 0
MarioMoveYEnd:
	.even
	.radix	8

; animate some coins
CoinsAni:
	bit	#^B11, FrameCnt
	bne	99$
CoinsAniCur =: .+2
	mov	#000001, R4
	mov	#Coins, R5
	mov	(R5)+, R3
10$:	mov	(R5)+, R0
	movb	R4, TilesMap(R0)
	tstb	TBufStat(R0)
	bpl	20$
	clrb	TBufStat(R0)
20$:	sob	R3, 10$
	; rotate
	inc	R4
	cmp	R4, #4
	blos	30$
	mov	#1, R4
30$:	mov	R4, CoinsAniCur
99$:	return


; move gumba left-right
GumbaMove:
	mov	#Gumba, R0
	tst	C_SPR_DIR(R0)
	bne	10$
	add	#2, C_SPR_X(R0)
	cmp	C_SPR_X(R0), #14.*16.-14.
	blo	99$
	inc	C_SPR_DIR(R0)
	return
10$:	sub	#2, C_SPR_X(R0)
	cmp	C_SPR_X(R0), #6.*16.
	bhi	99$
	clr	C_SPR_DIR(R0)
99$:	return


; move shroom left-right
ShroomMove:
	mov	#Shroom, R0
	tst	C_SPR_DIR(R0)
	bne	10$
	inc	C_SPR_X(R0)
	cmp	C_SPR_X(R0), #14.*16.-14.
	blo	99$
	inc	C_SPR_DIR(R0)
	return
10$:	dec	C_SPR_X(R0)
	cmp	C_SPR_X(R0), #6.*16.
	bhi	99$
	clr	C_SPR_DIR(R0)
99$:	return


; fill initial TBuf's from level map
InitTBuf:
	mov	#TBufStat, R0
	mov	#TilesMap, R1
	mov	#TBufTile, R2
	mov	#FIELD_DX*FIELD_DY, R3
10$:	clrb	(R0)+
	cmpb	(R1), TileExtMin
	blos	20$
	movb	(R1), TileExtMin
20$:	movb	(R1)+, (R2)+
	sob	R3, 10$
	; clear rows 1/2
	mov	#TBufTile, R0
	mov	#FIELD_DX*2, R3
30$:	clrb	(R0)+
	sob	R3, 30$
	return


; draw from 'framebuffer' (here is no framebuffer but..)
UpdateScreen:
	mov	#TBufStat, R5
	mov	#FIELD_DX*FIELD_DY, R4
10$:	movb	(R5), R0
	bpl	100$
30$:	inc	R5
	sob	R4, 10$
	return
100$:	; draw it
	movb	TBufTile-TBufStat(R5), R0	; R0 - tile #
	swab	R0
	asr	R0
	asr	R0				; *64. (tile size)
	add	#TileData000, R0		; R0 - tile addr
	mov	R5, R2
	sub	#TBufStat, R2			; # in buffer
	mov	R2, R1
	bic	#^B1111111111110000, R1		; X of tile
	asl	R1
	asl	R1
	bic	#^B1111111100001111, R2		; Y of tile * 16.
	swab	R2
	clc
	ror	R2
	asr	R2
	add	R1, R2
	add	#C_VADDR, R2
	; R0 - tile addr, R2 - vaddr
	mov	#C_SCRWID-4, R1
	mov	#10, R3
120$:	mov	(R0)+, (R2)+
	mov	(R0)+, (R2)+
	add	R1, R2
	mov	(R0)+, (R2)+
	mov	(R0)+, (R2)+
	add	R1, R2
	sob	R3, 120$
	; restore bgr, decrease stat and continue to cycle
	movb	TilesMap-TBufStat(R5), TBufTile-TBufStat(R5)
	decb	(R5)
	br	30$


; prepare sprite data
; adjust pix data from X coord
; make some other preparations
; R0 - sprite data addr
PrepareSprite:
	mov	C_SPR_IDATA(R0), C_SPR_DATA(R0)
	mov	C_SPR_X(R0), R1
	asr	R1
	asr	R1
	bcc	10$
	add	#128., C_SPR_DATA(R0)
10$:	mov	R1, C_SPR_X4(R0)
	return


; merge sprite in tile map 
; R0 - sprite data addr
BufferSprite:
	; get first tile # (upper left corner for sprite)
	mov	C_SPR_X4(R0), R5
	mov	R5, R4
	bic	#^B1111111111111100, R4
	mov	R4, -(SP)			; save 0..3 of X
	asr	R5
	asr	R5				; X byte in tile map
	mov	C_SPR_Y(R0), R4
	mov	R4, R3
	bic	#^B1111111111110000, R3
	mov	R3, -(SP)
	bic	#^B1111, R4			; (Y/16)*16
	add	R4, R5				; R5 - index of upper left
	; upper left
	call	CreateExtTile			; else copy background to ext tile
	call	DrawUpperLeft
	movb	#1, TBufStat(R5)		; mark as 'draw tile'
	; check upper right
	tst	2(SP)
	beq	10$
	inc	R5
	call	CreateExtTile
	call	DrawUpperRight
	movb	#1, TBufStat(R5)
	dec	R5
10$:	; check lower
	tst	(SP)
	beq	20$
	add	#FIELD_DX, R5
	call	CreateExtTile
	call	DrawLowerLeft
	movb	#1, TBufStat(R5)
	; check lower right
	tst	2(SP)
	beq	20$
	inc	R5
	call	CreateExtTile
	call	DrawLowerRight
	movb	#1, TBufStat(R5)
20$:	cmp	(SP)+, (SP)+
	return


; copy bgr tile data to ext tile
; R5 - index
; return R4 - new tile #
CreateExtTile:
	movb	TBufTile(R5), R4
	cmpb	R4, TileExtMin
	bhi	99$				; already have that additional tile
	inc	TileExtCur
	swab	R4
	asr	R4
	asr	R4
	add	#TileData000, R4		; R4 - copy from
	mov	TileExtCur, R3
	swab	R3
	asr	R3
	asr	R3
	add	#TileData000, R3		; R3 - copy to
	.rept 16.
	mov	(R4)+, (R3)+
	mov	(R4)+, (R3)+
	.endr
	mov	TileExtCur, R4
	movb	R4, TBufTile(R5)
99$:	return


; helper R4 from index to tile data
R4toTileData:
	swab	R4
	asr	R4
	asr	R4
	add	#TileData000, R4
	return


; draw upper left corner of sprite to ext tile
; R0 - spr data
; R4 - tile # where to draw
DrawUpperLeft:
	mov	R0, -(SP)
	call	R4toTileData
	; compute dx-s
	mov	(R0)+, R1			; X (byte)
	bic	#^B1111111111111100, R1		; 0..3
	mov	R1, DrawDX1
	sub	#4, R1
	neg	R1
	mov	R1, DrawDX2
	; compute dy-s
	mov	(R0)+, R2			; Y (line)
	bic	#^B1111111111110000, R2		; 0..15
	mov	R2, DrawDY1
	sub	#16., R2
	neg	R2
	mov	R2, DrawDY2
	; draw from addr
	mov	(R0)+, R0
	; draw to addr
	add	DrawDX1, R4
	mov	DrawDY1, R1
	asl	R1
	asl	R1
	add	R1, R4
	; adjust vals
	mov	DrawDX2, R1
	mov	DrawDY2, R3
	mov	DrawDX1, DULofsTo
	mov	DrawDX1, DULofsFrom
DULdraw =: .
	; draw
	asl	DULofsFrom
10$:	mov	R1, R2
20$:	bicb	(R0)+, (R4)
	bisb	(R0)+, (R4)+
	sob	R2, 20$
DULofsTo =: .+2
	add	#000000, R4
DULofsFrom =: .+2
	add	#000000, R0
	sob	R3, 10$
	mov	(SP)+, R0
	return

DrawDX1:	.word	0
DrawDY1:	.word	0
DrawDX2:	.word	0
DrawDY2:	.word	0

; draw upper right corner
; R0 - spr data
; R4 - tile # where to draw
DrawUpperRight:
	mov	R0, -(SP)
	call	R4toTileData
	; draw from addr
	mov	C_SPR_DATA(R0), R0
	mov	DrawDX2, R1
	asl	R1
	add	R1, R0
	; draw to addr
	mov	DrawDY1, R1
	asl	R1
	asl	R1
	add	R1, R4
	; adjust vals
	mov	DrawDX1, R1
	mov	DrawDY2, R3
	mov	DrawDX2, DULofsTo
	mov	DrawDX2, DULofsFrom
	; draw
	jmp	DULdraw


; draw lower left corner
; R0 - spr data
; R4 - tile # where to draw
DrawLowerLeft:
	mov	R0, -(SP)
	call	R4toTileData
	; draw from addr
	mov	C_SPR_DATA(R0), R0
	mov	DrawDY2, R1
	asl	R1
	asl	R1
	asl	R1
	add	R1, R0
	; draw to addr
	add	DrawDX1, R4
	; adjust vals
	mov	DrawDX2, R1
	mov	DrawDY1, R3
	mov	DrawDX1, DULofsTo
	mov	DrawDX1, DULofsFrom
	; draw
	jmp	DULdraw


; draw lower right corner
; R0 - spr data
; R4 - tile # where to draw
DrawLowerRight:
	mov	R0, -(SP)
	call	R4toTileData
	; draw from addr
	mov	C_SPR_DATA(R0), R0
	mov	DrawDY2, R1
	asl	R1
	asl	R1
	asl	R1
	add	R1, R0
	mov	DrawDX2, R1
	asl	R1
	add	R1, R0
	; draw to addr	
	; adjust vals
	mov	DrawDX1, R1
	mov	DrawDY1, R3
	mov	DrawDX2, DULofsTo
	mov	DrawDX2, DULofsFrom
	; draw
	jmp	DULdraw


; /////////////////////////////////////////////////////////////////////////////
; // Gfx
; /////////////////////////////////////////////////////////////////////////////

